# Public browser configuration (the Supabase anon key is intentionally public and RLS-limited)
PUBLIC_SUPABASE_URL=
PUBLIC_SUPABASE_ANON_KEY=

# Cloudflare Pages Functions only. Never expose these in browser JavaScript.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
APP_ORIGIN=http://localhost:8788
CORS_ALLOWED_ORIGINS=http://localhost:8788
SESSION_COOKIE_NAME=kastiz_session
REFRESH_COOKIE_NAME=kastiz_refresh
CSRF_COOKIE_NAME=kastiz_csrf
LOG_LEVEL=info
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_SECONDS=60
APP_ENV=development

# Reserved for future protected provider data. Generate outside source control.
ENCRYPTION_KEY=
ENCRYPTION_KEY_VERSION=1

# ONE Pass is opt-in and fails closed. Keep sensitive/real execution flags false until audited staging is complete.
ONE_PASS_ENABLED=false
IDENTITY_VAULT_ENABLED=false
PASSPORT_PERSISTENCE_ENABLED=false
PASSKEY_REAUTH_ENABLED=false
REAL_BOOKING_ENABLED=false
REAL_PAYMENTS_ENABLED=false
IDENTITY_VAULT_PROVIDER=disabled
DEVELOPMENT_VAULT_KEY_BASE64=
PRODUCTION_VAULT_KEY_REFERENCE=
WEBAUTHN_RP_ID=
WEBAUTHN_ORIGIN=
WEBAUTHN_CHALLENGE_TTL_SECONDS=300
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra
OPENAI_REASONING_EFFORT=medium
OPENAI_AGENT_ENABLED=false
OPENAI_STREAMING_ENABLED=false
OPENAI_REQUEST_TIMEOUT_MS=30000
OPENAI_MAX_OUTPUT_TOKENS=4000
OPENAI_MAX_TOOL_ITERATIONS=8
OPENAI_MAX_RETRIES=1
OPENAI_PROJECT_ID=
